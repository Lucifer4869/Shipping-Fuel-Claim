# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=ShippingDB
DB_HOST=db
DB_PORT=5432

# Backend Configuration
ASPNETCORE_ENVIRONMENT=Development
# JWT_KEY should be a long random string
JWT_KEY=your_secret_jwt_key_here
JWT_ISSUER=TopTechBackend
JWT_AUDIENCE=TopTechFrontend

# Google Auth (Get this from Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id_here

# Ports
BACKEND_PORT=5000
FRONTEND_PORT=5173
